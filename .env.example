# AI GPU Energy Optimizer - Environment Variables
# Copy this file to .env.local or .env and fill in your values

# ============================================
# BACKEND (FastAPI)
# ============================================

# Port for the backend server
PORT=10000

# Valid API keys (comma-separated for multiple keys)
VALID_API_KEYS=test_key_123,gpu_opt_demo

# ============================================
# DATABASE (Optional - for production)
# ============================================

# PostgreSQL (commented out until needed)
# DATABASE_URL=postgresql://user:password@localhost:5432/gpu_metrics
# POSTGRES_USER=gpu_optimizer
# POSTGRES_PASSWORD=change_me
# POSTGRES_DB=gpu_metrics

# ============================================
# REDIS (Optional - for caching)
# ============================================

# REDIS_URL=redis://localhost:6379

# ============================================
# INFLUXDB (Optional - time-series metrics)
# ============================================

# INFLUXDB_URL=http://localhost:8086
# INFLUXDB_TOKEN=your_token_here
# INFLUXDB_ORG=your_org
# INFLUXDB_BUCKET=gpu_metrics

# ============================================
# NVIDIA DCGM (Optional - for real GPU metrics)
# ============================================

# DCGM_HOST=localhost
# DCGM_PORT=9400

# ============================================
# FRONTEND (Next.js)
# ============================================

# Backend API URL for frontend
NEXT_PUBLIC_API_URL=https://ai-gpu-brain-v2.onrender.com
NEXT_PUBLIC_WS_URL=wss://ai-gpu-brain-v2.onrender.com/ws
