# ============================================
# AI GPU Energy Optimizer — Production Config
# Copy to .env and fill in values
# ============================================

# API
PORT=10000
ADMIN_SECRET=change-me-to-something-strong

# API Keys (comma-separated)
VALID_API_KEYS=key1,key2,key3

# PostgreSQL (TimescaleDB)
DATABASE_URL=postgresql://optimizer:password@localhost:5432/gpu_metrics
POSTGRES_USER=optimizer
POSTGRES_PASSWORD=change-me
POSTGRES_DB=gpu_metrics

# Redis
REDIS_URL=redis://localhost:6379

# GPU Agent
API_URL=https://ai-gpu-brain-v3.onrender.com
NODE_ID=node-001
POLL_INTERVAL=5
FLUSH_INTERVAL=30

# Prometheus
PROMETHEUS_ENABLED=true
METRICS_PORT=9090

# Ghost Detection Thresholds
GHOST_POWER_THRESHOLD_W=90
DESYNC_POWER_THRESHOLD_W=100
DESYNC_UTIL_THRESHOLD_PCT=5
LOCKED_MEM_CLOCK_MHZ=1593

# Frontend
NEXT_PUBLIC_API_URL=https://ai-gpu-brain-v3.onrender.com
NEXT_PUBLIC_WS_URL=wss://ai-gpu-brain-v3.onrender.com/ws
