import os, json
from fastapi import FastAPI, HTTPException
from typing import List, Dict, Any
app = FastAPI()
def find_test_result(base_dir, test_id):
    if not os.path.isdir(base_dir): return None
    folders = os.listdir(base_dir)
    exact = os.path.join(base_dir, test_id, "result.json")
    if os.path.exists(exact): return exact
    if test_id.startswith("test-") and test_id[5:].isdigit():
        num = int(test_id[5:]); test_id = f"test-{num:02d}"
    for f in folders:
        if f.startswith(test_id):
            cand = os.path.join(base_dir, f, "result.json")
            if os.path.exists(cand): return cand
    if test_id.isdigit():
        padded = f"test-{int(test_id):02d}"
        for f in folders:
            if f == padded or f.startswith(padded):
                cand = os.path.join(base_dir, f, "result.json")
                if os.path.exists(cand): return cand
    return None
@app.get("/results/a100")
def get_all_a100():
    base = "/opt/render/project/src/ai-er/a100"
    out = []
    if os.path.isdir(base):
        for f in os.listdir(base):
            p = os.path.join(base, f, "result.json")
            if os.path.exists(p):
                with open(p) as fp: out.append(json.load(fp))
    return out
@app.get("/results/a100/count")
def count_a100():
    base = "/opt/render/project/src/ai-er/a100"
    c = 0
    if os.path.isdir(base):
        for f in os.listdir(base):
            if os.path.exists(os.path.join(base, f, "result.json")):
                c += 1
    return {"total_a100_tests": c}
@app.get("/results/a100/{test_id}")
def get_a100(test_id: str):
    base = "/opt/render/project/src/ai-er/a100"
    path = find_test_result(base, test_id)
    if not path: raise HTTPException(404, f"Test '{test_id}' not found")
    with open(path) as f: return json.load(f)
